PORT=3000
# En hébergement production, définir explicitement : production
NODE_ENV=production

# Supabase — URL du projet (Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
# Clé serveur uniquement (bypass RLS). Nouveaux projets : clé secrète sb_secret_... dans le tableau des clés.
# Ancienne appellation : JWT service_role. Ne pas utiliser la clé sb_publishable_ (équivalent anon, site web / mobile).
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_KEY=

# Twilio SMS (OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Origines autorisées pour le front web (séparées par des virgules). Fortement recommandé en production.
# Exemple : https://app.votredomaine.com,https://www.votredomaine.com
# Laisse vide pour autoriser toutes les origines (pratique pour apps mobiles sans header Origin).
CORS_ORIGINS=
