PORT=3000
NODE_ENV=development

# Supabase (clé service = droits complets, à garder secrète côté serveur uniquement)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=

# Twilio SMS (OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Origines autorisées pour les apps web / outils admin (séparées par des virgules).
# Exemple : https://mon-app.expo.dev,http://localhost:8081
# Laisse vide en dev pour autoriser toutes les origines (y compris apps mobiles sans header Origin).
CORS_ORIGINS=
